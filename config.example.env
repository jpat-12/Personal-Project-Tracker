# Copy this to  config.env  and fill in your values.
# config.env is gitignored — your real secrets never get committed.
#
# Telegram poller (optional): leave both blank to run the board with no Telegram.
# Get the token from @BotFather; chat id is your numeric Telegram user/chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Claude-powered Telegram interface (optional): leave blank to keep the old
# rigid "#Category !Priority Title | Description" parser. Set an API key to
# let Claude parse free-form messages, decide which tool to call (add/update
# project or task, add category, search), or ask you a clarifying question
# back over Telegram when your message is ambiguous. Get a key from
# https://console.anthropic.com/ — costs apply per message (Claude Opus).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Password protection (optional): leave blank to keep the board open to anyone
# with the URL. If set, the board shows a login screen; one shared password,
# session remembered for 30 days per browser. Pick a real passphrase.
TRACKER_PASSWORD=

# Web server
PORT=8182
BIND=0.0.0.0
